<Window x:Class="WorkshopSentinel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workshop Sentinel"
        Width="900" Height="600"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar (real widgets added in M3) -->
        <DockPanel Grid.Row="0" Background="#F4F4F4" LastChildFill="False" Margin="0">
            <TextBlock DockPanel.Dock="Left"
                       Text="Workshop Sentinel"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="12,8" />
            <TextBlock DockPanel.Dock="Right"
                       x:Name="VersionLabel"
                       Margin="12,8"
                       Foreground="#666" />
        </DockPanel>

        <!-- Body (DataGrid added in M3) -->
        <Border Grid.Row="1" Background="White" Padding="24">
            <TextBlock x:Name="BodyLabel"
                       Text="Scaffold ready. Audit grid lands in M3."
                       Foreground="#999"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#F4F4F4" Padding="12,6">
            <TextBlock x:Name="StatusLabel" Text="Ready" Foreground="#666" />
        </Border>
    </Grid>
</Window>
