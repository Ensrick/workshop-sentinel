<Window x:Class="WorkshopSentinel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WorkshopSentinel.ViewModels"
        Title="Workshop Sentinel"
        Width="1100" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        TextElement.Foreground="#EAEAEA"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <vm:StatusToBrushConverter x:Key="StatusBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style TargetType="DataGrid">
            <Setter Property="Background"           Value="#252525" />
            <Setter Property="Foreground"           Value="#EAEAEA" />
            <Setter Property="RowBackground"        Value="#252525" />
            <Setter Property="AlternatingRowBackground" Value="#2B2B2B" />
            <Setter Property="GridLinesVisibility"  Value="None" />
            <Setter Property="BorderThickness"      Value="0" />
            <Setter Property="HeadersVisibility"    Value="Column" />
            <Setter Property="AutoGenerateColumns"  Value="False" />
            <Setter Property="CanUserAddRows"       Value="False" />
            <Setter Property="CanUserDeleteRows"    Value="False" />
            <Setter Property="CanUserResizeRows"    Value="False" />
            <Setter Property="IsReadOnly"           Value="True" />
            <Setter Property="SelectionMode"        Value="Extended" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"  Value="#1A1A1A" />
            <Setter Property="Foreground"  Value="#BBBBBB" />
            <Setter Property="BorderBrush" Value="#1A1A1A" />
            <Setter Property="Padding"     Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding"     Value="6,3" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#37404F" />
                    <Setter Property="Foreground" Value="#EAEAEA" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Padding"          Value="10,4" />
            <Setter Property="Margin"           Value="4,2" />
            <Setter Property="Background"       Value="#2D5FAF" />
            <Setter Property="Foreground"       Value="White" />
            <Setter Property="BorderThickness"  Value="0" />
            <Setter Property="Cursor"           Value="Hand" />
        </Style>
        <Style TargetType="Button" x:Key="DangerButton" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#A14336" />
        </Style>
        <!-- Tabs: keep both selected + unselected on the dark palette. Default WPF templates
             flip the selected tab to near-white system color, which against our #1E1E1E body
             made the tab strip read as bright white with a faint label. -->
        <Style TargetType="TabItem">
            <Setter Property="Padding"          Value="14,6" />
            <Setter Property="Background"       Value="#2A2A2A" />
            <Setter Property="Foreground"       Value="#CCCCCC" />
            <Setter Property="BorderBrush"      Value="#1E1E1E" />
            <Setter Property="BorderThickness"  Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}" Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True" TextBlock.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"   Value="#37404F" />
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="#5A9BFF" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333A45" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background"      Value="#1E1E1E" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="#1A1A1A" />
            <Setter Property="Foreground"  Value="#EAEAEA" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="Padding"     Value="6,3" />
            <Setter Property="CaretBrush"  Value="#EAEAEA" />
        </Style>

        <!-- ComboBox + dropdown popup: WPF's default templates revert the dropdown Popup to
             SystemColors.WindowBrush (white). Override the item rows (ComboBoxItem) AND replace
             the ComboBox ControlTemplate so the Popup's chrome is on the dark palette. -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background"   Value="#1A1A1A" />
            <Setter Property="Foreground"   Value="#EAEAEA" />
            <Setter Property="Padding"      Value="6,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#37404F" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D5FAF" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"   Value="#1A1A1A" />
            <Setter Property="Foreground"   Value="#EAEAEA" />
            <Setter Property="BorderBrush"  Value="#3A3A3A" />
            <Setter Property="Padding"      Value="6,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="22" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.ColumnSpan="2" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" />
                            <ContentPresenter Grid.Column="0" Margin="6,3"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False"
                                              VerticalAlignment="Center" />
                            <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent" BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}">
                                            <Path Data="M 0 0 L 5 5 L 10 0 Z" Fill="#BBBBBB"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox + ListBox for the friends-picker (added in this revision). -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAEAEA" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background"      Value="#1A1A1A" />
            <Setter Property="Foreground"      Value="#EAEAEA" />
            <Setter Property="BorderBrush"     Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#EAEAEA" />
            <Setter Property="Padding"    Value="4,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#37404F" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2F38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#161616" Padding="12,6">
            <DockPanel>
                <TextBlock x:Name="StatusLabel" Text="Ready." Foreground="#888" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock x:Name="VersionLabel" Foreground="#555" VerticalAlignment="Center" />
                    <TextBlock x:Name="UpdateStatusLabel" Foreground="#888" VerticalAlignment="Center" Margin="8,0,0,0" />
                    <Button x:Name="UpdateButton" Content="Update" Style="{StaticResource ActionButton}"
                            Margin="8,0,0,0" Visibility="Collapsed" Click="OnUpdateClicked" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Update-available banner. Additive to the footer cue: more prominent placement at the
             top of the window, dismissible per-session via "Later" (the footer label/button
             remain visible as a tertiary cue and reappear next launch if not acted on). -->
        <Border x:Name="UpdateBanner" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="#2D5FAF" BorderBrush="#7AB0FF" BorderThickness="0,0,0,2"
                Padding="16,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="UpdateBannerInstallButton" Content="Update now"
                            Style="{StaticResource ActionButton}" Background="#1A1A1A"
                            Margin="0,0,8,0" Click="OnUpdateClicked" />
                    <Button x:Name="UpdateBannerLaterButton" Content="Later"
                            Style="{StaticResource ActionButton}" Background="#3A4658"
                            Click="OnUpdateBannerLaterClicked" />
                </StackPanel>
                <TextBlock x:Name="UpdateBannerText" VerticalAlignment="Center"
                           Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <TabControl x:Name="MainTabs">
            <!-- ========================= TAB 1: GAMES ========================= -->
            <TabItem Header="Games">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Installed games with Workshop subscriptions"
                                   FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Content="Rescan" Style="{StaticResource ActionButton}"
                                Margin="20,0,0,0" Click="OnRescanGamesClicked" />
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="GamesGrid"
                              MouseDoubleClick="OnGamesGridDoubleClicked">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Game" Binding="{Binding Name}" Width="2*" />
                            <DataGridTextColumn Header="AppID" Binding="{Binding AppId}" Width="100" />
                            <DataGridTextColumn Header="Subs" Binding="{Binding SubCountText}" Width="80" />
                            <DataGridTextColumn Header="Stale" Binding="{Binding StaleText}" Width="80" />
                            <DataGridTextColumn Header="Library" Binding="{Binding LibraryRoot}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ========================= TAB 2: MY MODS ========================= -->
            <!--
                The friend picker lives in the left sidebar. Friends added from there become
                extra columns on the right grid: ✓ when they're subscribed, ▢ when they're not.
                The "You" column is interactive — ✓ unsubscribes, + subscribes. Mods a friend
                has that the local user doesn't show up as additional rows with the audit
                columns blank ("—").
            -->
            <TabItem Header="My Mods">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Game:" VerticalAlignment="Center" />
                        <ComboBox x:Name="MyModsGameCombo" Width="320" Margin="8,0,12,0"
                                  DisplayMemberPath="Name" SelectedValuePath="AppId"
                                  SelectionChanged="OnMyModsGameChanged" />
                        <Button Content="Audit"             Style="{StaticResource ActionButton}" Click="OnAuditClicked" />
                        <Button Content="Refresh selected"  Style="{StaticResource DangerButton}" Click="OnRefreshSelectedClicked" />
                        <Button Content="Refresh ALL stale" Style="{StaticResource DangerButton}" Click="OnRefreshAllStaleClicked" />
                        <Button Content="Refresh ALL friends-only" Style="{StaticResource DangerButton}" Click="OnRefreshAllUnknownClicked" />
                        <Button Content="Refresh EVERY mod (nuclear)" Style="{StaticResource DangerButton}" Click="OnRefreshAllItemsClicked" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" x:Name="MyModsHint" Foreground="#888" Margin="0,0,0,8"
                               Text="Pick a game and click Audit. Add friends from the sidebar — extra columns show what they have. Click the You ✓/+ icon to (un)subscribe via Steam." />

                    <!-- Body: left = Steam friends sidebar, right = mod grid -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Sidebar: Steam friends picker (formerly on the Compare tab) -->
                        <DockPanel Grid.Column="0">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Steam Friends" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button Content="Reload"         Style="{StaticResource ActionButton}" Click="OnReloadFriendListClicked" />
                                <Button Content="Refresh online" Style="{StaticResource ActionButton}" Click="OnRefreshOnlineStatusClicked" />
                            </StackPanel>
                            <TextBlock DockPanel.Dock="Top" Foreground="#888" FontSize="11" Margin="0,0,0,4"
                                       Text="Click + to add a friend as a column on the right. Star = favorite (persists)." />
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBox x:Name="FriendInput" Width="200" KeyDown="OnFriendInputKeyDown" />
                                <Button Content="+"     Style="{StaticResource ActionButton}" Click="OnAddFriendClicked"   ToolTip="Add by SteamID / vanity / URL" />
                                <Button Content="Clear" Style="{StaticResource DangerButton}" Click="OnClearFriendsClicked" />
                            </StackPanel>
                            <ListBox x:Name="FriendsListBox">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel LastChildFill="True" Margin="0,1">
                                            <ToggleButton DockPanel.Dock="Left" Width="22" Height="22"
                                                          Background="Transparent" BorderThickness="0"
                                                          IsChecked="{Binding IsFavorite, Mode=TwoWay}"
                                                          Click="OnFriendFavoriteToggled"
                                                          ToolTip="Mark as favorite (sorts to top)">
                                                <TextBlock Text="{Binding FavoriteIcon}" Foreground="#F5C84B" FontSize="14" />
                                            </ToggleButton>
                                            <TextBlock DockPanel.Dock="Left" Text="{Binding OnlineIcon}"
                                                       Foreground="{Binding OnlineColor}" FontSize="14"
                                                       Width="18" TextAlignment="Center" VerticalAlignment="Center" />
                                            <Button DockPanel.Dock="Right" Content="+" Width="28"
                                                    Style="{StaticResource ActionButton}" Padding="0"
                                                    Click="OnAddFriendFromListClicked" ToolTip="Add this friend as a column" />
                                            <TextBlock Text="{Binding PersonaName}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" Margin="4,0" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>

                        <!-- Mods grid. Friend columns get appended in code-behind whenever
                             the friend list changes. -->
                        <DataGrid Grid.Column="2" x:Name="MyModsGrid">
                            <DataGrid.Columns>
                                <!-- You: interactive toggle. ✓ = subscribed, + = not. -->
                                <DataGridTemplateColumn Header="You" Width="56">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding YouIcon}" ToolTip="{Binding YouTooltip}"
                                                    Click="OnYouToggleClicked"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    FontSize="15" FontWeight="Bold"
                                                    Width="32" Height="26" Padding="0"
                                                    Background="Transparent" BorderThickness="1"
                                                    BorderBrush="#444"
                                                    Cursor="Hand" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="" Width="36">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusIcon}" FontSize="16" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{Binding StatusText, Converter={StaticResource StatusBrush}}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Status"   Binding="{Binding StatusText}" Width="90" />
                                <DataGridTextColumn Header="Title"    Binding="{Binding Title}"      Width="3*" />
                                <DataGridTextColumn Header="Local"    Binding="{Binding LocalTime}"  Width="100" />
                                <DataGridTextColumn Header="Live"     Binding="{Binding RemoteTime}" Width="100" />
                                <DataGridTextColumn Header="Δ"        Binding="{Binding Delta}"      Width="100" />
                                <DataGridTextColumn Header="Size"     Binding="{Binding SizeText}"   Width="80" />
                                <DataGridTextColumn Header="ID"       Binding="{Binding PublishedFileId}" Width="120" />
                                <DataGridTemplateColumn Header="" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Refresh" Style="{StaticResource ActionButton}"
                                                    Click="OnRefreshRowClicked"
                                                    Visibility="{Binding IsRefreshable, Converter={StaticResource BoolToVisibility}}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
